<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Size: 6dp width, minimum 32dp height -->
    <size
        android:width="6dp"
        android:height="32dp" />
    
    <!-- 3dp rounded corners -->
    <corners android:radius="3dp" />
    
    <!-- Pressed state: more opaque white -->
    <solid android:color="#99FFFFFF" />
    
    <!-- 2dp padding -->
    <padding
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp" />
</shape> 