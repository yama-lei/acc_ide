<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/content_background"
    android:clickable="true"
    android:focusable="true">

    <!-- 顶部工具栏 - 无下边框 -->
    <LinearLayout
        android:id="@+id/io_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/content_background"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 运行按钮  -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/run_code_button"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="80dp"
            android:paddingHorizontal="12dp"
            android:text="@string/run"
            android:textSize="14sp"
            app:backgroundTint="@color/blue_500"
            app:cornerRadius="18dp"
            app:icon="@android:drawable/ic_media_play"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:iconPadding="4dp" />

        <!-- 运行状态 -->
        <TextView
            android:id="@+id/run_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            tools:text="AC" />

    </LinearLayout>

    <!-- 执行模式选择器 -->
    <LinearLayout
        android:id="@+id/execution_mode_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="start"
        app:layout_constraintTop_toBottomOf="@id/io_toolbar">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cloud_mode"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:paddingHorizontal="16dp"
            android:layout_marginEnd="8dp"
            android:text="@string/cloud_execution"
            android:textSize="13sp"
            app:backgroundTint="@color/blue_500"
            app:icon="@android:drawable/ic_menu_upload"
            app:iconSize="14dp"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:cornerRadius="18dp"
            app:strokeWidth="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_local_mode"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:paddingHorizontal="16dp"
            android:layout_marginStart="8dp"
            android:text="@string/local_execution"
            android:textSize="13sp"
            android:textColor="@color/blue_500"
            app:backgroundTint="?attr/colorSurface"
            app:icon="@android:drawable/ic_menu_myplaces"
            app:iconSize="14dp"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconTint="@color/blue_500"
            app:cornerRadius="18dp"
            app:strokeColor="@color/blue_500"
            app:strokeWidth="2dp" />
    </LinearLayout>

    <!-- 内容区域 - 无顶部边框 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:background="@color/content_background"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/execution_mode_container"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 输入区域 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/input"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="120dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 实际输出区域 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/actual_output"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/actual_output_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="120dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:fontFamily="monospace" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 答案输出区域 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/expected_output"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/expected_output_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="120dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout> 