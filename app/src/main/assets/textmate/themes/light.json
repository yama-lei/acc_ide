				"foreground": "#9E9E9E"
			}
		},
		{
			"name": "Markdown Bold",
			"scope": "markup.bold.markdown",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markdown Link Title/Description",
			"scope": "string.other.link.title.markdown,string.other.link.description.markdown",
			"settings": {
				"foreground": "#0288D1"
			}
		},
		{
			"name": "Markdown Underline Link/Image",
			"scope": "markup.underline.link.markdown,markup.underline.link.image.markdown",
			"settings": {
				"foreground": "#2E7D32"
			}
		},
		{
			"name": "Markdown Emphasis",
			"scope": "markup.italic.markdown",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "markup.strikethrough",
			"settings": {
				"fontStyle": "strikethrough"
			}
		},
		{
			"name": "Markdown Punctuation Definition Link",
			"scope": "markup.list.unnumbered.markdown, markup.list.numbered.markdown",
			"settings": {
				"foreground": "#212121"
			}
		},
		{
			"name": "Markdown List Punctuation",
			"scope": [
				"punctuation.definition.list.begin.markdown"
			],
			"settings": {
				"foreground": "#0288D1"
			}
		},
		{
			"scope": "token.info-token",
			"settings": {
				"foreground": "#0288D1"
			}
		},
		{
			"scope": "token.warn-token",
			"settings": {
				"foreground": "#F57F17"
			}
		},
		{
			"scope": "token.error-token",
			"settings": {
				"foreground": "#C2185B"
			}
		},
		{
			"scope": "token.debug-token",
			"settings": {
				"foreground": "#6A1B9A"
			}
		},
		{
			"name": "this.self",
			"scope": "variable.language",
			"settings": {
				"foreground": "#E65100"
			}
		},
		{
			"name": "Rainbow Bracket - Round Parentheses",
			"scope": [
				"punctuation.section.parens.begin",
				"punctuation.section.parens.end",
				"punctuation.definition.parameters"
			],
			"settings": {
				"foreground": "#0277BD"
			}
		},
		{
			"name": "Rainbow Bracket - Square Brackets",
			"scope": [
				"punctuation.section.brackets.begin",
				"punctuation.section.brackets.end",
				"punctuation.definition.array",
				"punctuation.definition.brackets"
			],
			"settings": {
				"foreground": "#E65100"
			}
		},
		{
			"name": "Rainbow Bracket - Curly Braces",
			"scope": [
				"punctuation.section.block.begin",
				"punctuation.section.block.end",
				"punctuation.definition.block",
				"punctuation.definition.curly"
			],
			"settings": {
				"foreground": "#6A1B9A"
			}
		},
		{
			"name": "Rainbow Bracket - Angle Brackets",
			"scope": [
				"punctuation.definition.tag.begin",
				"punctuation.definition.tag.end",
				"punctuation.definition.generic"
			],
			"settings": {
				"foreground": "#F57F17"
			}
		}
