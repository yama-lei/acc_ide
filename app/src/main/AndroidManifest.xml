<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" 
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.AccIDE"
        android:enableOnBackInvokedCallback="true"
        android:versionCode="121"
        android:versionName="1.2.1"
        tools:targetApi="33">
        
        <activity
            android:name="com.acc_ide.ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AccIDE.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name="com.acc_ide.ui.main.MainActivity"
            android:configChanges="locale|layoutDirection|uiMode"
            android:exported="false">
        </activity>
    </application>

</manifest>